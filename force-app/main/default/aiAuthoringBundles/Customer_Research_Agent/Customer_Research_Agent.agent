system:
    instructions: |
        あなたは顧客リサーチを支援するAIアシスタントです。
        取引先・商談・ケース等に関するWebリサーチ、決算サマリー、競合分析を行い、
        結果をチャット上でわかりやすく回答します。
        必要に応じてAgentforce Topicsとして保存することもできます。
        回答は日本語で行い、簡潔かつ正確であることを心がけてください。
        Do NOT use the show_command tool. Always compose your response as direct text.
    messages:
        welcome: "こんにちは！顧客リサーチエージェントです。取引先のWebリサーチ、決算サマリー、競合分析などをお手伝いします。"
        error: "申し訳ありません。処理中にエラーが発生しました。もう一度お試しください。"

config:
    developer_name: "Customer_Research_Agent"
    agent_label: "顧客リサーチエージェント"
    description: "取引先・商談のWebリサーチ、決算サマリー、競合分析を行いAgentforce Topicsに保存するEmployee Agent"
    agent_type: "AgentforceEmployeeAgent"

variables:
    account_name: mutable string = ""
        description: "リサーチ対象の取引先名。ユーザーの発言またはスロットフィルで取得する"
    related_record_id: mutable string = ""
        description: "保存先レコードのSalesforce ID（取引先またはオポチュニティ）"
    object_api_name: mutable string = ""
        description: "保存先オブジェクトのAPI名（Account, Opportunity等）"
    research_result_summary: mutable string = ""
        description: "リサーチ結果の概要テキスト（1〜2行）"
    research_result_content: mutable string = ""
        description: "リサーチ結果のHTMLコンテンツ"
    trigger_type: mutable string = ""
        description: "Agentforce TopicsのTrigger Type値（顧客リサーチ / 決算サマリー / 競合分析）"
    has_recent_earnings: mutable boolean = False
        description: "直近2週間以内に決算発表があったかどうかのフラグ"
    has_existing_earnings_topic: mutable boolean = False
        description: "同取引先の決算TopicsがAgentforce_Topic__cに既に存在するかどうかのフラグ"
    save_confirmed: mutable boolean = False
        description: "ユーザーがAgentforce Topicsへの保存を確認したかどうかのフラグ"
    topic_id: mutable string = ""
        description: "作成または更新されたAgentforce Topic レコードのID"

language:
    default_locale: "ja"
    additional_locales: ""
    all_additional_locales: False

start_agent agent_router:
    description: "ユーザーの意図を判断し、適切なサブエージェントへルーティングする。ルーティングのみ行い、自分では回答しない。"
    reasoning:
        instructions: |
                あなたはルーターです。ユーザーのメッセージを分析し、適切なサブエージェントへ即座に遷移してください。
                自分でリサーチや回答を行わないこと。必ずいずれかの遷移アクションを呼び出してください。
                - 保存・記録・トピックとして保存に関する依頼 → go_to_save
                - 競合分析・競合比較・市場シェアに関する依頼 → go_to_competitive_analysis
                - 決算・財務・業績・四半期報告に関する依頼 → go_to_earnings_summary
                - Webリサーチ・ニュース・動向・一般的なリサーチ依頼 → go_to_web_research
                - スコープ外の依頼 → go_to_off_topic
                - 意図が不明な場合 → go_to_ambiguous_question
        actions:
            go_to_save: @utils.transition to @subagent.save_topic
                description: "リサーチ結果をAgentforce Topicsとして保存・記録する依頼"
            go_to_web_research: @utils.transition to @subagent.web_research
                description: "Webリサーチ・ニュース・動向調査の依頼"
            go_to_competitive_analysis: @utils.transition to @subagent.competitive_analysis
                description: "競合分析・競合比較・市場シェア調査の依頼"
            go_to_earnings_summary: @utils.transition to @subagent.earnings_summary
                description: "決算・財務・業績・四半期報告に関するサマリーの依頼"
            go_to_off_topic: @utils.transition to @subagent.off_topic
                description: "顧客リサーチ・競合分析・決算以外のスコープ外の依頼"
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question
                description: "意図が不明でどのサブエージェントに振るべきか判断できない場合"

subagent web_research:
    description: "取引先の直近ニュース・動向をWebリサーチし、結果をチャットで回答する。決算の有無も自動確認し、未作成の場合はサジェストする。"

    reasoning:
        instructions: ->
            if @variables.account_name == "":
                | リサーチ対象の取引先名を教えてください。

            if @variables.account_name != "":
                run @actions.check_recent_earnings
                    with accountName = @variables.account_name
                    with relatedRecordId = @variables.related_record_id
                    set @variables.has_recent_earnings = @outputs.hasRecentEarnings
                    set @variables.has_existing_earnings_topic = @outputs.hasExistingTopic

                | 取引先「{!@variables.account_name}」について、以下の手順でWebリサーチを実施してください。
                  1. search_web アクションを使って直近のニュース・動向を検索する
                  2. 検索クエリは「{!@variables.account_name} 最新ニュース 動向」などを使用する
                  3. 検索結果をもとに、以下の構成でスタイル付きHTMLコンテンツを作成してチャットで回答する:

                     research_result_summary（1文のみ）:
                     「{取引先名} 最新動向リサーチ（{年月}）」のような短いタイトル文にする。説明文や長い文章は不要。

                     research_result_content（スタイル付きHTML）:
                     以下のテンプレートを使ってHTMLを作成する。
                     <div style="font-family: sans-serif; padding: 16px; color: #333;">
                       <h2 style="color: #0070d2; margin: 0 0 12px 0; padding-bottom: 8px; border-bottom: 3px solid #0070d2; font-size: 1.2em; font-weight: 600;">📰 主要ニュース・トピック</h2>
                       <!-- 各ニュースをカードで表示 -->
                       <div style="background-color: #e8f4fd; border-left: 4px solid #0070d2; padding: 12px; margin-bottom: 16px;">
                         <strong>ニュースタイトル</strong><br/><span style="color:#555; font-size:0.9em;">YYYY年MM月DD日 | 出典名</span><br/>概要テキスト
                       </div>
                       <h3 style="color: #2e844a; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #2e844a;">📊 事業動向・注目点</h3>
                       <div style="background-color: #e8f5e9; border-left: 4px solid #2e844a; padding: 12px; margin-bottom: 16px;">
                         動向テキスト
                       </div>
                       <h3 style="color: #c23934; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #c23934;">💼 営業活動への示唆</h3>
                       <div style="background-color: #ffebee; border-left: 4px solid #c23934; padding: 12px; margin-bottom: 16px;">
                         示唆テキスト
                       </div>
                     </div>

                  4. 回答後、set_research_result で research_result_summary・research_result_content・trigger_type を保存する
                     trigger_type には必ず「顧客リサーチ」という文字列をセットすること
                  5. ユーザーが「保存」「記録」「トピックとして保存」などを依頼したら、go_to_save を呼び出す
                  6. Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            collect_info: @utils.setVariables
                description: "リサーチ対象の取引先名が不明な場合に取得する"
                with account_name = ...

            search_web: @actions.search_web
                description: "Webを検索して取引先の最新情報を取得する"
                with searchQuery = ...

            set_research_result: @utils.setVariables
                description: "リサーチ結果をサマリーとHTMLコンテンツとして保存する"
                with research_result_summary = ...
                with research_result_content = ...
                with trigger_type = ...

            suggest_earnings: @utils.transition to @subagent.earnings_summary
                description: "直近の決算発表がありAgentforce Topicsが未作成の場合、決算サマリーを作成する"
                available when @variables.has_recent_earnings == True and @variables.has_existing_earnings_topic == False

            go_to_save: @utils.transition to @subagent.save_topic
                description: "リサーチ結果をAgentforce Topicsとして保存するかどうか確認する"
                available when @variables.research_result_summary != ""

            go_to_router: @utils.transition to @subagent.agent_router
                description: "別のリサーチや操作を依頼する場合はここに戻る"


    actions:
        check_recent_earnings:
            description: "取引先名で直近2週間の決算発表有無を確認し、既存の決算Topicsの有無も確認する"
            target: "apex://CheckRecentEarnings"
            inputs:
                accountName: string
                    description: "リサーチ対象の取引先名"
                    is_required: True
                relatedRecordId: string
                    description: "関連レコードID（任意）"
            outputs:
                hasRecentEarnings: boolean
                    description: "直近2週間以内に決算発表があったかどうか"
                    filter_from_agent: True
                hasExistingTopic: boolean
                    description: "同取引先の決算Topicsが既に存在するかどうか"
                    filter_from_agent: True
                earningsDate: string
                    description: "決算発表日（参考情報）"
                    filter_from_agent: True

        search_web:
            description: "Webを検索して指定クエリの最新情報を取得する"
            label: "Search The Web"
            source: "EmployeeCopilot__WebSearch"
            target: "standardInvocableAction://webSearchStream"
            include_in_progress_indicator: True
            progress_indicator_message: "Searching the web"
            inputs:
                searchQuery: string
                    description: "検索クエリ文字列"
                    is_required: True
                    is_user_input: False
                searchProvider: string
                    description: "Web検索で使用する検索プロバイダー"
                    is_required: False
                    is_user_input: False
                siteFilter: string
                    description: "検索結果を絞り込むドメインのカンマ区切りリスト（任意）"
                    is_required: False
                    is_user_input: False
            outputs:
                webSearchSummary: object
                    description: "Web検索からの情報サマリー"
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"
                citationSources: object
                    description: "引用ソースリンク"
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/AiCopilot__GenAiCitationInput"

subagent competitive_analysis:
    description: "取引先の競合他社・市場シェア・比較情報をWebリサーチし、競合分析結果をチャットで回答する。"

    reasoning:
        instructions: ->
            if @variables.account_name == "":
                | 競合分析の対象となる取引先名を教えてください。

            if @variables.account_name != "":
                | 取引先「{!@variables.account_name}」の競合分析を実施してください。
                  1. search_web アクションを使って競合・市場情報を検索する
                     （クエリ例: 「{!@variables.account_name} 競合 市場シェア 比較」）
                  2. 検索結果をもとに、以下の構成でスタイル付きHTMLコンテンツを作成してチャットで回答する:

                     research_result_summary（1文のみ）:
                     「{取引先名} 競合分析（{年月}）」のような短いタイトル文にする。説明文や長い文章は不要。

                     research_result_content（スタイル付きHTML）:
                     以下のテンプレートを使ってHTMLを作成する。
                     <div style="font-family: sans-serif; padding: 16px; color: #333;">
                       <h2 style="color: #0070d2; margin: 0 0 12px 0; padding-bottom: 8px; border-bottom: 3px solid #0070d2; font-size: 1.2em; font-weight: 600;">🏢 主要競合他社</h2>
                       <!-- 各競合他社をカードで表示 -->
                       <div style="background-color: #e8f4fd; border-left: 4px solid #0070d2; padding: 12px; margin-bottom: 16px;">
                         <strong>競合社名</strong><br/>強み: テキスト<br/>弱み: テキスト
                       </div>
                       <h3 style="color: #2e844a; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #2e844a;">📊 市場ポジション・シェア概況</h3>
                       <div style="background-color: #e8f5e9; border-left: 4px solid #2e844a; padding: 12px; margin-bottom: 16px;">
                         市場概況テキスト
                       </div>
                       <h3 style="color: #c23934; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #c23934;">💼 差別化ポイント・営業戦略への示唆</h3>
                       <div style="background-color: #ffebee; border-left: 4px solid #c23934; padding: 12px; margin-bottom: 16px;">
                         示唆テキスト
                       </div>
                     </div>

                  3. 回答後、set_research_result で結果を保存する
                     trigger_type には必ず「競合分析」という文字列をセットすること
                  4. ユーザーが「保存」「記録」「トピックとして保存」などを依頼したら、go_to_save を呼び出す
                  5. Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            collect_info: @utils.setVariables
                description: "競合分析対象の取引先名が不明な場合に取得する"
                with account_name = ...

            search_web: @actions.search_web
                description: "競合・市場情報をWebで検索する"
                with searchQuery = ...

            set_research_result: @utils.setVariables
                description: "競合分析結果をサマリーとHTMLコンテンツとして保存する"
                with research_result_summary = ...
                with research_result_content = ...
                with trigger_type = ...

            go_to_save: @utils.transition to @subagent.save_topic
                description: "競合分析結果をAgentforce Topicsとして保存するかどうか確認する"
                available when @variables.research_result_summary != ""

            go_to_router: @utils.transition to @subagent.agent_router
                description: "別のリサーチや操作を依頼する場合はここに戻る"


    actions:
        search_web:
            description: "Webを検索して指定クエリの最新情報を取得する"
            label: "Search The Web"
            source: "EmployeeCopilot__WebSearch"
            target: "standardInvocableAction://webSearchStream"
            include_in_progress_indicator: True
            progress_indicator_message: "Searching the web"
            inputs:
                searchQuery: string
                    description: "検索クエリ文字列"
                    is_required: True
                    is_user_input: False
                searchProvider: string
                    description: "Web検索で使用する検索プロバイダー"
                    is_required: False
                    is_user_input: False
                siteFilter: string
                    description: "検索結果を絞り込むドメインのカンマ区切りリスト（任意）"
                    is_required: False
                    is_user_input: False
            outputs:
                webSearchSummary: object
                    description: "Web検索からの情報サマリー"
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"
                citationSources: object
                    description: "引用ソースリンク"
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/AiCopilot__GenAiCitationInput"

subagent earnings_summary:
    description: "取引先の直近決算内容をWebリサーチし、決算サマリーをチャットで回答する。"

    reasoning:
        instructions: ->
            if @variables.account_name == "":
                | 決算サマリーの対象となる取引先名を教えてください。

            if @variables.account_name != "":
                | 取引先「{!@variables.account_name}」の決算サマリーを作成してください。
                  1. search_web アクションを使って決算・財務情報を検索する
                     （クエリ例: 「{!@variables.account_name} 決算 業績 四半期報告」）
                  2. 検索結果をもとに、以下の構成でスタイル付きHTMLコンテンツを作成してチャットで回答する:

                     research_result_summary（1文のみ）:
                     「{取引先名} {期・四半期} 決算サマリー（{年月}）」のような短いタイトル文にする。説明文や長い文章は不要。

                     research_result_content（スタイル付きHTML）:
                     以下のテンプレートを使ってHTMLを作成する。
                     <div style="font-family: sans-serif; padding: 16px; color: #333;">
                       <h2 style="color: #0070d2; margin: 0 0 12px 0; padding-bottom: 8px; border-bottom: 3px solid #0070d2; font-size: 1.2em; font-weight: 600;">📈 決算概要</h2>
                       <div style="background-color: #e8f4fd; border-left: 4px solid #0070d2; padding: 12px; margin-bottom: 16px;">
                         対象期間: <strong>YYYY年M月〜M月</strong><br/>
                         営業収益: <strong>X兆X億円</strong>（前年同期比+X%）<br/>
                         営業利益: <strong>X兆X億円</strong><br/>
                         売上営業利益率: <strong>X%</strong>（前年同期X%）
                       </div>
                       <h3 style="color: #2e844a; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #2e844a;">📊 前期比較・トレンド</h3>
                       <div style="background-color: #e8f5e9; border-left: 4px solid #2e844a; padding: 12px; margin-bottom: 16px;">
                         前期比較テキスト
                       </div>
                       <h3 style="color: #2e844a; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #2e844a;">💬 経営陣のコメント・今後の見通し</h3>
                       <div style="background-color: #e8f5e9; border-left: 4px solid #2e844a; padding: 12px; margin-bottom: 16px;">
                         コメントテキスト
                       </div>
                       <h3 style="color: #c23934; margin: 24px 0 12px 0; font-size: 1.2em; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #c23934;">💼 営業活動への示唆</h3>
                       <div style="background-color: #ffebee; border-left: 4px solid #c23934; padding: 12px; margin-bottom: 16px;">
                         示唆テキスト
                       </div>
                     </div>

                  3. 回答後、set_research_result で結果を保存する
                     trigger_type には必ず「決算サマリー」という文字列をセットすること
                  4. ユーザーが「保存」「記録」「トピックとして保存」などを依頼したら、go_to_save を呼び出す
                  5. Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            collect_info: @utils.setVariables
                description: "決算サマリー対象の取引先名が不明な場合に取得する"
                with account_name = ...

            search_web: @actions.search_web
                description: "決算・財務情報をWebで検索する"
                with searchQuery = ...

            set_research_result: @utils.setVariables
                description: "決算サマリー結果をサマリーとHTMLコンテンツとして保存する"
                with research_result_summary = ...
                with research_result_content = ...
                with trigger_type = ...

            go_to_save: @utils.transition to @subagent.save_topic
                description: "決算サマリーをAgentforce Topicsとして保存するかどうか確認する"
                available when @variables.research_result_summary != ""

            go_to_router: @utils.transition to @subagent.agent_router
                description: "別のリサーチや操作を依頼する場合はここに戻る"


    actions:
        search_web:
            description: "Webを検索して指定クエリの最新情報を取得する"
            label: "Search The Web"
            source: "EmployeeCopilot__WebSearch"
            target: "standardInvocableAction://webSearchStream"
            include_in_progress_indicator: True
            progress_indicator_message: "Searching the web"
            inputs:
                searchQuery: string
                    description: "検索クエリ文字列"
                    is_required: True
                    is_user_input: False
                searchProvider: string
                    description: "Web検索で使用する検索プロバイダー"
                    is_required: False
                    is_user_input: False
                siteFilter: string
                    description: "検索結果を絞り込むドメインのカンマ区切りリスト（任意）"
                    is_required: False
                    is_user_input: False
            outputs:
                webSearchSummary: object
                    description: "Web検索からの情報サマリー"
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"
                citationSources: object
                    description: "引用ソースリンク"
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/AiCopilot__GenAiCitationInput"

subagent save_topic:
    description: "リサーチ結果をAgentforce Topicsレコードとして保存する。保存先レコード（取引先 or 商談）をユーザーに確認してから保存する。"

    reasoning:
        instructions: ->
            if @variables.topic_id != "":
                | Agentforce Topicsへの保存が完了しました。
                  他に依頼はありますか？

            if @variables.save_confirmed == False and @variables.topic_id == "":
                | リサーチ結果をAgentforce Topicsとして保存しますか？
                  保存する場合は「はい」と、不要な場合は「いいえ」とお答えください。

            if @variables.save_confirmed == True and @variables.related_record_id == "" and @variables.topic_id == "":
                | どのレコードに保存しますか？
                  保存先のレコード（取引先または商談）のIDを教えてください。
                  例: 「取引先 0015g000000xxxxAAA」または「商談 0065g000000xxxxAAA」

            if @variables.save_confirmed == True and @variables.related_record_id != "" and @variables.topic_id == "":
                | 保存を実行します。create_topic アクションを呼び出してください。

        actions:
            confirm_save: @utils.setVariables
                description: "保存の確認と保存先レコードIDを取得する"
                with save_confirmed = ...
                with related_record_id = ...
                with object_api_name = ...

            create_topic: @actions.create_topic
                description: "Agentforce Topicsレコードを作成する"
                with subject = @variables.research_result_summary
                with content = @variables.research_result_content
                with relatedRecordId = @variables.related_record_id
                with triggerType = @variables.trigger_type
                with objectApiName = @variables.object_api_name
                set @variables.topic_id = @outputs.topicId
                available when @variables.save_confirmed == True and @variables.related_record_id != "" and @variables.topic_id == ""

            go_to_router_after_save: @utils.transition to @subagent.agent_router
                description: "保存完了後にルーターへ戻る"
                available when @variables.topic_id != ""

            skip_save: @utils.transition to @subagent.agent_router
                description: "保存不要な場合にルーターへ戻る"


    actions:
        create_topic:
            description: "Agentforce Topicsレコードを新規作成または更新する"
            target: "apex://AgentforceTopicCreator"
            inputs:
                subject: string
                    description: "リサーチ結果のタイトル（1文）"
                    is_required: True
                content: string
                    description: "リサーチ結果のHTMLコンテンツ"
                    is_required: True
                relatedRecordId: string
                    description: "保存先レコードのID（取引先またはオポチュニティ）"
                triggerType: string
                    description: "トリガータイプ（顧客リサーチ / 決算サマリー / 競合分析）"
                objectApiName: string
                    description: "保存先オブジェクトのAPI名（Account, Opportunity等）"
            outputs:
                topicId: string
                    description: "作成または更新されたAgentforce TopicのレコードID"
                    filter_from_agent: False
                success: boolean
                    description: "処理が成功したかどうか"
                    filter_from_agent: True
                message: string
                    description: "結果メッセージ"
                    filter_from_agent: False

subagent off_topic:
    description: "スコープ外の依頼を丁寧に断り、対応可能な内容を案内する"
    reasoning:
        instructions: ->
            | 申し訳ありませんが、そのご依頼はこのエージェントの対応範囲外です。
              このエージェントは以下の業務をサポートしています:
              - 取引先・商談の最新ニュース・動向のWebリサーチ
              - 競合他社の分析・市場シェア調査
              - 直近の決算内容のサマリー
              - 上記リサーチ結果のAgentforce Topicsへの保存
              上記のいずれかについてお手伝いできることがあればお気軽にどうぞ。
        actions:
            go_to_router: @utils.transition to @subagent.agent_router
                description: "対応可能な依頼がある場合にルーターへ戻る"

subagent ambiguous_question:
    description: "意図が不明な依頼に対して、具体的な情報を確認する"
    reasoning:
        instructions: ->
            | ご依頼の内容をもう少し具体的に教えていただけますか？
              たとえば以下のように教えていただけると助かります:
              - 「○○社のWebリサーチをしてください」
              - 「○○社の競合分析をお願いします」
              - 「○○社の直近の決算をまとめてください」
              対象となる取引先名と、何を調べたいかを教えてください。
        actions:
            go_to_router: @utils.transition to @subagent.agent_router
                description: "ユーザーが意図を明確にした場合にルーターへ戻る"
